.cache/
fastembed_cache/

# ─── IDE ─────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ─── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

