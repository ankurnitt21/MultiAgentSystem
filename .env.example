# ============================================================================
# UNIFIED MULTI-AGENT SYSTEM - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your API keys.
# Never commit .env to version control.

# ─── LLM (Groq) ─────────────────────────────────────────────────────────────
# Get your API key at: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant

# ─── Pinecone Vector Store ───────────────────────────────────────────────────
# Get your API key at: https://app.pinecone.io/
# Create two indexes: rag-base (384 dim, cosine) and sql-base (384 dim, cosine)
PINECONE_API_KEY=
PINECONE_RAG_INDEX=rag-base
PINECONE_SQL_INDEX=sql-base

# ─── SQL Database (Warehouse - PostgreSQL) ───────────────────────────────────
# Defaults match docker/docker-compose.yml
SQL_DATABASE_URL=postgresql+asyncpg://warehouse_admin:warehouse_secret_2024@localhost:5433/warehouse_db
SQL_DATABASE_URL_SYNC=postgresql://warehouse_admin:warehouse_secret_2024@localhost:5433/warehouse_db

# ─── Redis (Semantic Cache with RediSearch) ──────────────────────────────────
# Requires Redis Stack (includes RediSearch module) - see docker-compose.yml
REDIS_URL=redis://localhost:6379

# ─── LangSmith Observability (optional) ─────────────────────────────────────
# Get your API key at: https://smith.langchain.com/
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=UnifiedMultiAgentSystem

# ─── OpenTelemetry → LangSmith (optional) ───────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=https://api.smith.langchain.com/otel
OTEL_EXPORTER_OTLP_HEADERS=x-api-key=YOUR_LANGSMITH_API_KEY
OTEL_SERVICE_NAME=UnifiedMultiAgentSystem

# ─── Guardrails ──────────────────────────────────────────────────────────────
GUARDRAILS_ENABLED=true

# ─── Embedding (ONNX via fastembed) ──────────────────────────────────────────
# Model downloaded automatically on first run
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ─── Semantic Cache ──────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=300
SEMANTIC_CACHE_THRESHOLD=0.92

# ─── Memory ──────────────────────────────────────────────────────────────────
MEMORY_TOKEN_LIMIT=4000
MEMORY_MAX_MESSAGES=20

# ─── Schema Retrieval ────────────────────────────────────────────────────────
SCHEMA_TOP_K=10
RAG_TOP_K=10
RAG_DOMAINS=HR,PRODUCT,AI